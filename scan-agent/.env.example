# --- Path to the scanner script (in the cloned repo, forward slashes are fine) ---
SCAN_SCRIPT=C:/Users/<you>/LotAlfWeb/tools/scan_duplex.ps1

# --- Port the agent listens on (localhost only; the frontend uses VITE_SCAN_BASE) ---
PORT=8765

# --- Frontend origin(s) allowed to call the agent (comma-separated). ---
# Include wherever the Vue app is served from. For the live deployment use the
# production domain; add the Vite dev origins too if you also develop locally.
CORS_ORIGINS=https://losdecimosdeildefonso.com,https://www.losdecimosdeildefonso.com,http://localhost:5173

# --- Optional shared secret. If set, the frontend must send it as X-Scan-Token
#     (set VITE_SCAN_TOKEN to the same value). Recommended — see README §Security. ---
SCAN_TOKEN=
