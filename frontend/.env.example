# Frontend build-time config (Vite). Copy to .env and adjust. All optional.

# Base URL of the remote FastAPI backend. Empty = same origin (dev uses the Vite
# proxy in vite.config.js). Set to your deployed backend, e.g. https://api.example.com
VITE_API_BASE=

# --- Split deployment: local scan agent (see scan-agent/README.md) ---
# Where the local scan agent listens. Empty = no agent; scanning uses the backend's
# own /api/scan/duplex (only works when the backend runs on the scanner machine).
# Set this when the backend is remote and the scanner is on the user's machine:
VITE_SCAN_BASE=
# e.g. VITE_SCAN_BASE=http://localhost:8765

# Must match the agent's SCAN_TOKEN if you set one (recommended).
VITE_SCAN_TOKEN=
