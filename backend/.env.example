# --- Postgres (the MUTABLE collection: comments, numbers_collection, retailers_collection) ---
# The new backend reflects this schema at runtime; it never creates/drops/alters tables.
DB_USER=
DB_PASSWORD=
DB_ADDRESS=
DB_PORT=5432
DB_NAME=

# --- Flask session signing key reused so nothing about secrets changes ---
SECRET_KEY=change-me-to-a-long-random-string

# --- Edit mode (replaces the hardcoded password). If unset, falls back to the
#     legacy value with a startup warning so behaviour is preserved out-of-the-box. ---
EDIT_PASSWORD=

# --- SQLite reference data (towns + lottery_retailers). Defaults to the repo's bundled file. ---
LOCAL_DB_PATH=../app/lotalf.db

# --- Frontend origin(s) allowed by CORS (comma-separated). Vite dev server default below. ---
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Scanner: the Plustek D620 duplex helper (optional; powers the "Escanear" button) ---
SCAN_SCRIPT=C:/Users/Alfonso/Tools/scan_duplex.ps1

# --- OCR: Claude vision reads the administración seal off the scanned décimo to fill the form ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
